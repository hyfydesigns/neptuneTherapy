{
  "name": "neptune-therapy",
  "version": "1.0.0",
  "description": "Neptune Therapy – React frontend + Express backend",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" --names \"API,UI\" --prefix-colors \"blue,cyan\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "seed": "cd server && npm run seed",
    "build": "cd client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
