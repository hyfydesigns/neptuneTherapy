# ── Email Notifications ──────────────────────────────────────────────────────
# Emails are sent FROM this Gmail account (needs an App Password, not your regular password)
# Steps: myaccount.google.com → Security → 2-Step Verification → App Passwords → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password

# Email address that receives form submissions and new applications
NOTIFY_EMAIL=neptunehc.resources@yahoo.com
